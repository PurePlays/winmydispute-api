# 1) Environment
.env
.env.*                # any other local env variants

# 2) Node modules
node_modules/
disputegpt-rebuttal-api/node_modules/
gpt-config/node_modules/

# 3) OS cruft
.DS_Store
Thumbs.db

# 4) Backups / scratch files
disputegpt-backup/
temp.txt
.dbxignore

# 5) Generated PDFs (you can still open them locally; Git just won’t track them)
*.pdf

# 6) Local data stores (Stripe tokens / paid users, etc.)
paidUsers.json
tokens.json

# 7) Lockfile duplicates (if you ever have more than one)
**/package-lock.json

# 8) Unused plugin manifest
gpt-config/ai-plugin.json
